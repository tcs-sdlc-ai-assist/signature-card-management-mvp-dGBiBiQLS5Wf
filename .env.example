# ============================================
# Application Configuration
# ============================================
VITE_APP_TITLE=SIG Card Management

# ============================================
# Session Management
# ============================================
# Session timeout in milliseconds (default: 1800000 = 30 minutes)
VITE_SESSION_TIMEOUT_MS=1800000

# Session warning before timeout in milliseconds (default: 120000 = 2 minutes)
VITE_SESSION_WARNING_MS=120000

# ============================================
# Login Security
# ============================================
# Maximum number of failed login attempts before lockout (default: 5)
VITE_MAX_LOGIN_ATTEMPTS=5

# ============================================
# OTP (One-Time Password) Settings
# ============================================
# OTP expiry time in milliseconds (default: 300000 = 5 minutes)
VITE_OTP_EXPIRY_MS=300000

# Maximum number of OTP verification attempts (default: 3)
VITE_OTP_MAX_ATTEMPTS=3

# Cooldown period before allowing OTP resend in milliseconds (default: 60000 = 1 minute)
VITE_OTP_RESEND_COOLDOWN_MS=60000

# ============================================
# Token Configuration
# ============================================
# Token expiry time in hours (default: 24)
VITE_TOKEN_EXPIRY_HOURS=24

# ============================================
# Rate Limiting
# ============================================
# Maximum number of requests per day (default: 1000)
VITE_DAILY_RATE_LIMIT=1000